---
import Layout from "../../layouts/Layout.astro";
import CodeBlock from "../../ui/code-block.astro";
import type { MarkdownInstance } from "astro";
import { skills, type Skill } from "../../data/skills";
import { registry, type RegistrySkill } from "../../data/registry";
import SkillContentCard from "../../ui/skill-content-card.astro";
import Breadcrumbs from "../../ui/breadcrumbs.astro";
import { marked } from "marked";

type SkillFrontmatter = {
  name?: string;
  description?: string;
  label?: string;
};

const titleize = (value: string) =>
  value
    .split("-")
    .map((word) => `${word.charAt(0).toUpperCase()}${word.slice(1)}`)
    .join(" ");

const skillModules = import.meta.glob<MarkdownInstance<SkillFrontmatter>>(
  "/skills/*/SKILL.md",
  { eager: true },
);
const skillRawModules = import.meta.glob<string>("/skills/*/SKILL.md", {
  eager: true,
  query: "?raw",
  import: "default",
});
const skillEntries = Object.entries(skillModules).map(([path, module]) => {
  const entrySlug = path.split("/").at(-2) ?? "";

  return { slug: entrySlug, module };
});
const skillRawEntries = Object.entries(skillRawModules).map(([path, raw]) => {
  const entrySlug = path.split("/").at(-2) ?? "";

  return { slug: entrySlug, raw };
});

export function getStaticPaths() {
  const groupPaths = Array.from(
    new Set(
      skills.flatMap((skill: Skill) => {
        const segments = skill.pathSlug.split("/");
        if (segments.length <= 1) {
          return [];
        }

        return segments
          .slice(0, -1)
          .map((_: string, index: number) => segments.slice(0, index + 1).join("/"));
      }),
    ),
  );

  return [
    ...skills.map((skill) => ({
      params: { slug: skill.pathSlug },
    })),
    ...groupPaths.map((pathSlug) => ({
      params: { slug: pathSlug },
    })),
  ];
}

const routeSlug = Astro.params.slug ?? "";
const pathSlug = Array.isArray(routeSlug) ? routeSlug.join("/") : routeSlug;

const skillList: Skill[] = skills;
const skill = skillList.find((entry: Skill) => entry.pathSlug === pathSlug);
const children = skillList.filter((entry: Skill) => entry.pathSlug.startsWith(`${pathSlug}/`));
const isGroupPage = !skill && children.length > 0;
const segments = pathSlug.split("/");
const groupOwner = segments[0] ?? "";
const groupOwnerSkill = children.find(
  (entry: Skill) => (entry.sourceKey ?? entry.pathSlug.split("/")[0]) === groupOwner,
);
const groupTitle =
  groupOwnerSkill?.sourceLabel ?? titleize(segments[segments.length - 1] ?? "Skills");
const showOwnerProfile = isGroupPage && segments.length === 1 && Boolean(groupOwner);
const ownerAvatarUrl = showOwnerProfile
  ? `https://github.com/${groupOwner}.png?size=80`
  : "";
const ownerGithubUrl = showOwnerProfile ? `https://github.com/${groupOwner}` : "";
const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Skills", href: "/skills" },
  ...segments.map((segment: string, index: number) => {
    const currentPath = segments.slice(0, index + 1).join("/");
    const matchedSkill = skillList.find((entry: Skill) => entry.pathSlug === currentPath);
    const isLast = index === segments.length - 1;

    return {
      label: isLast && skill ? skill.label : matchedSkill?.label ?? titleize(segment),
      href: isLast ? undefined : `/skills/${currentPath}`,
    };
  }),
];

const relatedSkills = skill
  ? skillList
      .filter(
        (entry: Skill) =>
          entry.pathSlug !== skill.pathSlug &&
          entry.sourceKey &&
          entry.sourceKey === skill.sourceKey,
      )
      .slice(0, 10)
  : [];

let skillRaw = "";
let displayContent = "";
let SkillContent: any = null;
let githubUrl = "";

if (skill?.isRegistry) {
  const registryEntry = registry.find((entry: RegistrySkill) => entry.pathSlug === pathSlug);
  if (registryEntry) {
    try {
      const response = await fetch(registryEntry.rawUrl);
      if (response.ok) {
        skillRaw = await response.text();
        githubUrl = registryEntry.githubUrl;
        let contentToRender = skillRaw;

        if (contentToRender.startsWith("---")) {
          const parts = contentToRender.split("---");
          if (parts.length >= 3) {
            contentToRender = parts.slice(2).join("---").trim();
          }
        }
        displayContent = await marked.parse(contentToRender);
      } else {
        displayContent = `<p>Error: Failed to fetch skill content from ${registryEntry.rawUrl} (${response.status} ${response.statusText})</p>`;
      }
    } catch (e) {
      displayContent = `<p>Error: ${e instanceof Error ? e.message : String(e)}</p>`;
    }
  }
} else if (skill) {
  const localSlug = skill.slug;
  const skillModule = skillEntries.find((entry) => entry.slug === localSlug)?.module;
  skillRaw = skillRawEntries.find((entry) => entry.slug === localSlug)?.raw ?? "";
  SkillContent = skillModule?.Content;
}

const commandSegments = [
  { text: "npx", className: "text-[#953800]" },
  { text: " ui-skills", className: "text-[#0a3069]" },
  { text: " add", className: "text-[#0550ae]" },
  { text: ` ${skill?.slug ?? pathSlug}`, className: "text-parchment-400" },
];
---

<Layout llmsPath={skill ? `/skills/${pathSlug}/llms.txt` : undefined}>
  <div class="relative flex min-h-dvh flex-col items-center justify-start px-0 sm:px-4">
    <div class="relative mt-20 w-full max-w-3xl sm:px-0">
      <div class="mx-auto flex w-full flex-col gap-10">
        <Breadcrumbs items={breadcrumbItems} />

        {
          isGroupPage ? (
            <>
              <div class="px-4 sm:px-0">
                {showOwnerProfile ? (
                  <div class="flex items-center gap-3">
                    <a
                      href={ownerGithubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex rounded-full focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-primary"
                      aria-label={`Open ${groupTitle} GitHub profile`}
                    >
                      <img
                        src={ownerAvatarUrl}
                        alt={`${groupTitle} avatar`}
                        width="32"
                        height="32"
                        loading="lazy"
                        class="size-8 rounded-full border border-neutral-200"
                      />
                    </a>
                    <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
                      <a
                        href={ownerGithubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-parchment-700 transition-colors"
                      >
                        {groupTitle}
                      </a>
                    </h1>
                  </div>
                ) : (
                  <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
                    {groupTitle}
                  </h1>
                )}
              </div>

              <div class="grid gap-4 px-4 sm:grid-cols-2 sm:px-0">
                {children.map((entry) => (
                  <a
                    href={`/skills/${entry.pathSlug}`}
                    class="hover:border-parchment-300 hover:bg-parchment-100 relative flex flex-col justify-between rounded-[12px] border border-neutral-200 bg-transparent px-6 py-4 transition-colors"
                  >
                    <div class="flex flex-col gap-1">
                      <div class="text-parchment-900 font-[450] tracking-tight">
                        {entry.pathSlug}
                      </div>
                      {entry.description ? (
                        <div class="text-parchment-500 line-clamp-3 text-[14px] leading-snug">
                          {entry.description}
                        </div>
                      ) : null}
                    </div>
                  </a>
                ))}
              </div>
            </>
          ) : null
        }

        {
          skill ? (
            <>
              <div class="px-4 sm:px-0">
                <div class="mt-3 flex items-center gap-2">
                  <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
                    {skill.label}
                  </h1>
                  {githubUrl ? (
                    <a
                      href={githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="View skill source on GitHub"
                      class="text-parchment-500 hover:text-parchment-900 inline-flex size-9 items-center justify-center rounded-md transition-colors"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="size-6"
                        aria-hidden="true"
                      >
                        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.009-.866-.014-1.7-2.782.605-3.369-1.343-3.369-1.343-.454-1.157-1.11-1.466-1.11-1.466-.908-.62.069-.607.069-.607 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.748-1.026 2.748-1.026.546 1.378.203 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.338 4.695-4.566 4.943.359.31.678.922.678 1.859 0 1.341-.012 2.423-.012 2.752 0 .268.18.58.688.481A10.02 10.02 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z" />
                      </svg>
                    </a>
                  ) : null}
                </div>
                <p class="text-parchment-600 mt-3 text-lg">
                  {skill.description ?? "Install this skill with a single command."}
                </p>
              </div>

              <div>
                <h2 class="text-parchment-900 mb-3 px-4 text-lg font-medium tracking-tight sm:px-0">
                  Install
                </h2>
                <CodeBlock lines={[commandSegments]} align="center" />
              </div>

              <SkillContentCard
                copyContent={skillRaw}
                name={skill.name}
                description={skill.description}
                dataEvent="install"
              >
                {SkillContent ? <SkillContent /> : <div set:html={displayContent} />}
              </SkillContentCard>

              {relatedSkills.length > 0 ? (
                <div>
                  <h2 class="text-parchment-900 mb-3 px-4 text-lg font-medium tracking-tight sm:px-0">
                    More from {skill.sourceLabel}
                  </h2>
                  <div class="grid gap-3 px-4 sm:grid-cols-2 sm:px-0">
                    {relatedSkills.map((entry) => (
                      <a
                        href={`/skills/${entry.pathSlug}`}
                        class="hover:border-parchment-300 hover:bg-parchment-100 rounded-[10px] border border-neutral-200 px-4 py-3 transition-colors"
                      >
                        <div class="text-parchment-900 font-[450] tracking-tight">
                          {entry.pathSlug}
                        </div>
                        {entry.description ? (
                          <div class="text-parchment-500 mt-1 line-clamp-2 text-[14px] leading-snug">
                            {entry.description}
                          </div>
                        ) : null}
                      </a>
                    ))}
                  </div>
                </div>
              ) : null}
            </>
          ) : null
        }
      </div>
    </div>
  </div>
</Layout>
