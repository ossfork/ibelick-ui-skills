---
import Layout from "../../layouts/Layout.astro";
import CodeBlock from "../../ui/code-block.astro";
import { skills, type Skill } from "../../data/skills";
import { topicBySlug, relatedTopicSlugs } from "../../data/topics";
import type { TopicSlug } from "../../data/registry";
import { registry, type RegistrySkill } from "../../data/registry";
import SkillContentCard from "../../ui/skill-content-card.astro";
import Breadcrumbs from "../../ui/breadcrumbs.astro";
import SkillCard from "../../ui/skill-card.astro";
import SkillNav from "../../ui/skill-nav.astro";
import TopicTag from "../../ui/topic-tag.astro";
import { marked } from "marked";

const titleize = (value: string) =>
  value
    .split("-")
    .map((word) => `${word.charAt(0).toUpperCase()}${word.slice(1)}`)
    .join(" ");

const rewriteRelativeLinksToRepo = (html: string, baseUrl: string) =>
  html.replace(/href="([^"]+)"/g, (match, href: string) => {
    if (
      href.startsWith("http://") ||
      href.startsWith("https://") ||
      href.startsWith("mailto:") ||
      href.startsWith("#")
    ) {
      return match;
    }

    try {
      const resolved = new URL(href, baseUrl).toString();
      return `href="${resolved}"`;
    } catch {
      return match;
    }
  });

export function getStaticPaths() {
  const topicGroupPaths = Array.from(
    new Set(skills.flatMap((skill) => skill.topics ?? [])),
  );
  const legacySingleSkillPaths = Array.from(
    skills.reduce((acc, skill) => {
      const matches = skills.filter(
        (entry: Skill) => entry.slug === skill.slug,
      );
      if (matches.length === 1) {
        acc.add(skill.slug);
      }
      return acc;
    }, new Set<string>()),
  );
  const groupPaths = Array.from(
    new Set(
      skills.flatMap((skill: Skill) => {
        const segments = skill.pathSlug.split("/");
        if (segments.length <= 1) {
          return [];
        }

        return segments
          .slice(0, -1)
          .map((_: string, index: number) =>
            segments.slice(0, index + 1).join("/"),
          );
      }),
    ),
  );

  return [
    ...legacySingleSkillPaths.map((pathSlug) => ({
      params: { slug: pathSlug },
    })),
    ...topicGroupPaths.map((pathSlug) => ({
      params: { slug: pathSlug },
    })),
    ...groupPaths.map((pathSlug) => ({
      params: { slug: pathSlug },
    })),
    ...skills.map((skill) => ({
      params: { slug: skill.pathSlug },
    })),
    ...skills.map((skill) => ({
      params: { slug: `${skill.sourceKey}/${skill.slug}` },
    })),
  ];
}

const routeSlug = Astro.params.slug ?? "";
const pathSlug = Array.isArray(routeSlug) ? routeSlug.join("/") : routeSlug;
const segments = pathSlug.split("/");
const skillList: Skill[] = skills;
const bucket = segments[0] ?? "";
const leaf = segments[segments.length - 1] ?? "";
const topic = topicBySlug.get(bucket as TopicSlug);
const isTopicGroup = Boolean(topic) && segments.length === 1;
const singleSlugMatches =
  segments.length === 1
    ? skillList.filter((entry: Skill) => entry.slug === pathSlug)
    : [];
const uniqueSingleSlugMatch =
  singleSlugMatches.length === 1 ? singleSlugMatches[0] : undefined;
const skill =
  skillList.find((entry: Skill) => entry.pathSlug === pathSlug) ??
  uniqueSingleSlugMatch ??
  (segments.length === 2
    ? skillList.find(
        (entry: Skill) => entry.sourceKey === bucket && entry.slug === leaf,
      )
    : undefined) ??
  (Boolean(topic) && segments.length === 2
    ? skillList.find(
        (entry: Skill) =>
          entry.slug === leaf && entry.topics?.includes(bucket as TopicSlug),
      )
    : undefined);

if (skill && pathSlug !== skill.pathSlug) {
  return Astro.redirect(`/skills/${skill.pathSlug}`, 301);
}

const userChildren =
  !topic && segments.length === 1
    ? skillList.filter((entry: Skill) =>
        entry.pathSlug.startsWith(`${bucket}/`),
      )
    : [];

const topicChildren = isTopicGroup
  ? skillList.filter((entry: Skill) =>
      entry.topics?.includes(bucket as TopicSlug),
    )
  : [];

const children = [
  ...(topicChildren.length ? topicChildren : userChildren),
].sort((a, b) => a.pathSlug.localeCompare(b.pathSlug));

const isGroupPage = !skill && children.length > 0;
const groupOwner = bucket;
const groupOwnerSkill = children.find(
  (entry: Skill) =>
    (entry.sourceKey ?? entry.pathSlug.split("/")[0]) === groupOwner,
);
const groupTitle = isTopicGroup
  ? `${topic?.label ?? titleize(bucket)} skills`
  : (groupOwnerSkill?.sourceLabel ?? titleize(groupOwner));
const showOwnerProfile =
  !isTopicGroup && isGroupPage && segments.length === 1 && Boolean(groupOwner);
const ownerAvatarUrl = showOwnerProfile
  ? `https://github.com/${groupOwner}.png?size=80`
  : "";
const ownerGithubUrl = showOwnerProfile
  ? `https://github.com/${groupOwner}`
  : "";
const skillOwnerKey = skill?.sourceKey ?? "";
const skillOwnerLabel = skill
  ? (skill.sourceLabel ?? skill.sourceKey ?? "")
  : "";
const skillOwnerAvatarUrl = skillOwnerKey
  ? `https://github.com/${skillOwnerKey}.png?size=64`
  : "";
const canonicalSkillPath = skill ? skill.pathSlug : pathSlug;
const skillHref = (entry: Skill) => `/skills/${entry.pathSlug}`;
const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Skills", href: "/skills" },
  ...segments.map((segment: string, index: number) => {
    const currentPath = segments.slice(0, index + 1).join("/");
    const matchedSkill = skillList.find(
      (entry: Skill) => entry.pathSlug === currentPath,
    );
    const isLast = index === segments.length - 1;

    return {
      label:
        isLast && skill
          ? skill.name
          : (matchedSkill?.label ?? titleize(segment)),
      href: isLast ? undefined : `/skills/${currentPath}`,
    };
  }),
];

const relatedSkills = skill
  ? skillList
      .filter(
        (entry: Skill) =>
          entry.pathSlug !== skill.pathSlug &&
          entry.sourceKey &&
          entry.sourceKey === skill.sourceKey,
      )
      .slice(0, 10)
  : [];

const sortedSkills = [...skillList].sort((a, b) =>
  a.pathSlug.localeCompare(b.pathSlug),
);
const currentSkillIndex = skill
  ? sortedSkills.findIndex((entry: Skill) => entry.pathSlug === skill.pathSlug)
  : -1;
const previousSkill =
  skill && currentSkillIndex > 0
    ? sortedSkills[currentSkillIndex - 1]
    : undefined;
const nextSkill =
  skill && currentSkillIndex >= 0 && currentSkillIndex < sortedSkills.length - 1
    ? sortedSkills[currentSkillIndex + 1]
    : undefined;
const previousSkillHref = previousSkill
  ? `/skills/${previousSkill.pathSlug}`
  : undefined;
const nextSkillHref = nextSkill ? `/skills/${nextSkill.pathSlug}` : undefined;

const topicUsageCountBySlug = new Map<TopicSlug, number>();
for (const entry of skillList) {
  for (const topicSlug of entry.topics ?? []) {
    topicUsageCountBySlug.set(
      topicSlug,
      (topicUsageCountBySlug.get(topicSlug) ?? 0) + 1,
    );
  }
}

const relatedTopicsForTopicPage =
  isTopicGroup && topic
    ? (relatedTopicSlugs[topic.slug] ?? [])
        .filter((slug) => (topicUsageCountBySlug.get(slug) ?? 0) > 0)
        .map((slug) => topicBySlug.get(slug))
        .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry))
        .slice(0, 5)
    : [];

const skillTopicSuggestions = skill
  ? Array.from(
      new Set([
        ...(skill.topics ?? []),
        ...(skill.topics ?? []).flatMap(
          (slug) => relatedTopicSlugs[slug] ?? [],
        ),
      ]),
    )
      .filter((slug) => (topicUsageCountBySlug.get(slug as TopicSlug) ?? 0) > 0)
      .map((slug) => topicBySlug.get(slug as TopicSlug))
      .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry))
      .slice(0, 8)
  : [];

const isInvalidSkillsRoute = !skill && !isGroupPage;
if (isInvalidSkillsRoute) {
  Astro.response.status = 404;
}

const siteOrigin = Astro.site ?? new URL("https://www.ui-skills.com");
const pageUrl = new URL(`/skills/${canonicalSkillPath}`, siteOrigin).toString();
const shorten = (value: string, max = 160) =>
  value.length <= max ? value : `${value.slice(0, max - 1).trimEnd()}...`;

const buildSkillTitle = (entry: Skill) => {
  const source = entry.sourceLabel ?? "Community";
  return `${entry.name} Skill - ${source} | UI Skills`;
};

const buildSkillDescription = (entry: Skill) => {
  const source = entry.sourceLabel ?? "the community";
  const description =
    entry.description ??
    `Install ${entry.name} from ${source} with a copy-ready command and practical usage guidance.`;

  return shorten(`${description} Install from ${source} in one command.`);
};

const buildGroupTitle = (groupName: string) =>
  `${groupName} Skills Directory | UI Skills`;

const buildTopicTitle = (topicLabel: string) =>
  `${topicLabel} Skills for Design Engineers | UI Skills`;

const buildGroupDescription = (groupName: string, count: number) =>
  shorten(
    `Browse ${count} curated skills from ${groupName}. Discover installation commands and practical guides for your design engineering workflow.`,
  );
const buildTopicDescription = (
  topicLabel: string,
  description: string,
  count: number,
) =>
  shorten(
    `${description} Browse ${count} curated ${topicLabel.toLowerCase()} skills for design engineering and frontend workflows.`,
  );
const structuredData = skill
  ? {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      headline: skill.name,
      description:
        skill.description ?? "Install this skill with a single command.",
      url: pageUrl,
      mainEntityOfPage: pageUrl,
      author: {
        "@type": "Person",
        name: skill.sourceLabel ?? skill.sourceKey ?? "Ibelick",
        url: skill.sourceKey
          ? `https://github.com/${skill.sourceKey}`
          : "https://github.com/ibelick",
      },
      publisher: {
        "@type": "Organization",
        name: "UI Skills",
        url: new URL("/", siteOrigin).toString(),
      },
      about: ["Design Engineering", "Developer Tools", "AI Skills"],
      keywords: [skill.slug, skill.pathSlug, "design engineering skills"],
    }
  : isGroupPage
    ? {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        name: `${groupTitle} Skills`,
        description:
          isTopicGroup && topic
            ? topic.description
            : `Browse skills from ${groupTitle}.`,
        url: pageUrl,
        hasPart: {
          "@type": "ItemList",
          itemListElement: children.map((entry: Skill, index: number) => ({
            "@type": "ListItem",
            position: index + 1,
            url: new URL(skillHref(entry), siteOrigin).toString(),
            name: entry.label,
          })),
        },
      }
    : undefined;

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.label,
    item: new URL(
      item.href ?? `/skills/${canonicalSkillPath}`,
      siteOrigin,
    ).toString(),
  })),
};

const pageTitle = skill
  ? buildSkillTitle(skill)
  : isInvalidSkillsRoute
    ? "Skill Page Not Found | UI Skills"
    : isGroupPage
      ? isTopicGroup && topic
        ? buildTopicTitle(topic.label)
        : buildGroupTitle(groupTitle)
      : "Skills Directory for Design Engineers | UI Skills";

const pageDescription = skill
  ? buildSkillDescription(skill)
  : isInvalidSkillsRoute
    ? "The requested skills route does not match any skill, topic, or source page."
    : isGroupPage
      ? isTopicGroup && topic
        ? buildTopicDescription(topic.label, topic.description, children.length)
        : buildGroupDescription(groupTitle, children.length)
      : "Discover skills for design engineers across accessibility, motion, frontend craft, and UI quality.";

let skillRaw = "";
let displayContent = "";
let githubUrl = "";

if (skill) {
  const registryEntry = registry.find(
    (entry: RegistrySkill) => entry.pathSlug === skill.pathSlug,
  );

  if (registryEntry) {
    try {
      const response = await fetch(registryEntry.rawUrl);
      if (response.ok) {
        skillRaw = await response.text();
        githubUrl = registryEntry.githubUrl;
        let contentToRender = skillRaw;

        if (contentToRender.startsWith("---")) {
          const parts = contentToRender.split("---");
          if (parts.length >= 3) {
            contentToRender = parts.slice(2).join("---").trim();
          }
        }
        const parsedHtml = await marked.parse(contentToRender);
        displayContent = rewriteRelativeLinksToRepo(
          parsedHtml,
          registryEntry.githubUrl,
        );
      } else {
        displayContent = `<p>Error: Failed to fetch skill content from ${registryEntry.rawUrl} (${response.status} ${response.statusText})</p>`;
      }
    } catch (e) {
      displayContent = `<p>Error: ${e instanceof Error ? e.message : String(e)}</p>`;
    }
  }
}

const commandSegments = (() => {
  const registryEntry = skill
    ? registry.find((entry: RegistrySkill) => entry.pathSlug === skill.pathSlug)
    : undefined;
  const repoUrl = registryEntry
    ? `https://github.com/${registryEntry.user}/${registryEntry.repo}`
    : "https://github.com/ibelick/ui-skills";
  const skillName = registryEntry?.name ?? skill?.slug ?? canonicalSkillPath;

  return [
    { text: "npx", className: "text-[#953800]" },
    { text: " skills", className: "text-[#0a3069]" },
    { text: " add", className: "text-[#0550ae]" },
    { text: ` ${repoUrl}`, className: "text-parchment-400" },
    { text: " --skill", className: "text-[#0550ae]" },
    { text: ` ${skillName}`, className: "text-parchment-400" },
  ];
})();
---

<Layout
  structuredData={structuredData
    ? [structuredData, breadcrumbStructuredData]
    : breadcrumbStructuredData}
  title={pageTitle}
  description={pageDescription}
  robots={isInvalidSkillsRoute ? "noindex,follow" : undefined}
>
  <div
    class="relative flex min-h-dvh flex-col items-center justify-start px-0 sm:px-4"
  >
    <div class="relative mt-20 w-full max-w-3xl sm:px-0">
      <div class="mx-auto flex w-full flex-col gap-10">
        <div>
          <Breadcrumbs items={breadcrumbItems} />
        </div>

        {
          isGroupPage ? (
            <>
              <div class="px-4 sm:px-0">
                {showOwnerProfile ? (
                  <div class="flex items-center gap-3">
                    <a
                      href={ownerGithubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="focus-visible:outline-primary inline-flex rounded-full focus-visible:outline-1 focus-visible:outline-offset-2"
                      aria-label={`Open ${groupTitle} GitHub profile`}
                    >
                      <img
                        src={ownerAvatarUrl}
                        alt={`${groupTitle} avatar`}
                        width="32"
                        height="32"
                        loading="lazy"
                        class="size-8 rounded-full border border-neutral-200"
                      />
                    </a>
                    <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
                      <a
                        href={ownerGithubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-parchment-700 transition-colors"
                      >
                        {groupTitle}
                      </a>
                    </h1>
                  </div>
                ) : (
                  <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
                    {groupTitle}
                  </h1>
                )}
                {isTopicGroup && topic?.description ? (
                  <p class="text-parchment-500 mt-3 text-base">
                    {topic.description}
                  </p>
                ) : null}
              </div>

              <div class="grid gap-4 px-4 sm:grid-cols-2 sm:px-0">
                {children.map((entry) => (
                  <SkillCard
                    href={skillHref(entry)}
                    slug={entry.slug}
                    description={entry.description}
                    ownerLabel={
                      entry.sourceLabel ??
                      titleize(
                        entry.sourceKey ?? entry.pathSlug.split("/")[0] ?? "",
                      )
                    }
                    avatarUrl={`https://github.com/${entry.sourceKey ?? entry.pathSlug.split("/")[0]}.png?size=40`}
                  />
                ))}
              </div>

              {relatedTopicsForTopicPage.length > 0 ? (
                <div class="px-4 sm:px-0">
                  <h2 class="text-parchment-900 mb-3 text-lg font-medium tracking-tight">
                    Related topics
                  </h2>
                  <div class="flex flex-wrap gap-2">
                    {relatedTopicsForTopicPage.map((entry) => (
                      <TopicTag
                        href={`/skills/${entry.slug}`}
                        label={entry.label}
                      />
                    ))}
                  </div>
                </div>
              ) : null}
            </>
          ) : null
        }

        {
          skill ? (
            <>
              <div class="px-4 sm:px-0">
                <div class="mt-3 flex items-start justify-between gap-3">
                  <div class="flex items-center gap-2">
                    <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
                      {skill.name}
                    </h1>
                    {githubUrl ? (
                      <a
                        href={githubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="View skill source on GitHub"
                        class="text-parchment-500 hover:text-parchment-900 inline-flex size-9 items-center justify-center rounded-md transition-colors"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          class="size-6"
                          aria-hidden="true"
                        >
                          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.009-.866-.014-1.7-2.782.605-3.369-1.343-3.369-1.343-.454-1.157-1.11-1.466-1.11-1.466-.908-.62.069-.607.069-.607 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.748-1.026 2.748-1.026.546 1.378.203 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.338 4.695-4.566 4.943.359.31.678.922.678 1.859 0 1.341-.012 2.423-.012 2.752 0 .268.18.58.688.481A10.02 10.02 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z" />
                        </svg>
                      </a>
                    ) : null}
                  </div>
                  <SkillNav
                    previousHref={previousSkillHref}
                    nextHref={nextSkillHref}
                  />
                </div>
                {skillOwnerKey ? (
                  <a
                    href={`/skills/${skillOwnerKey}`}
                    class="mt-3 inline-flex items-center gap-2 transition-colors"
                    aria-label={`View more skills from ${skillOwnerLabel}`}
                  >
                    <img
                      src={skillOwnerAvatarUrl}
                      alt={`${skillOwnerLabel} avatar`}
                      width="22"
                      height="22"
                      loading="lazy"
                      class="size-[22px] rounded-full border border-neutral-200"
                    />
                    <span class="text-parchment-700 hover:text-parchment-900 text-[18px] leading-none font-[450]">
                      {skillOwnerLabel}
                    </span>
                  </a>
                ) : null}
                <p class="text-parchment-600 mt-3 text-lg">
                  {skill.description ??
                    "Install this skill with a single command."}
                </p>
              </div>

              <div>
                <h2 class="text-parchment-900 mb-3 px-4 text-lg font-medium sm:px-0">
                  Install
                </h2>
                <CodeBlock lines={[commandSegments]} align="center" truncate />
              </div>

              <SkillContentCard
                copyContent={skillRaw}
                name={skill.name}
                description={skill.description}
                dataEvent="install"
              >
                <div set:html={displayContent} />
              </SkillContentCard>

              {relatedSkills.length > 0 ? (
                <div>
                  <h2 class="text-parchment-900 mb-3 px-4 text-lg font-medium sm:px-0">
                    More from {skill.sourceLabel}
                  </h2>
                  <div class="grid gap-3 px-4 sm:grid-cols-2 sm:px-0">
                    {relatedSkills.map((entry) => (
                      <a
                        href={skillHref(entry)}
                        class="hover:border-parchment-300 hover:bg-parchment-100 rounded-[10px] border border-neutral-200 px-4 py-3 transition-colors"
                      >
                        <div class="text-parchment-900 font-[450]">
                          {entry.pathSlug}
                        </div>
                        {entry.description ? (
                          <div class="text-parchment-500 mt-1 line-clamp-2 text-[14px] leading-snug">
                            {entry.description}
                          </div>
                        ) : null}
                      </a>
                    ))}
                  </div>
                </div>
              ) : null}

              {skillTopicSuggestions.length > 0 ? (
                <div class="px-4 sm:px-0">
                  <h2 class="text-parchment-900 mb-3 text-lg font-medium">
                    Explore topics
                  </h2>
                  <div class="flex flex-wrap gap-2">
                    {skillTopicSuggestions.map((entry) => (
                      <TopicTag
                        href={`/skills/${entry.slug}`}
                        label={entry.label}
                      />
                    ))}
                  </div>
                </div>
              ) : null}
            </>
          ) : null
        }

        {
          isInvalidSkillsRoute ? (
            <div class="px-4 sm:px-0">
              <h1 class="text-parchment-900 text-3xl font-medium">
                Skill page not found
              </h1>
              <p class="text-parchment-500 mt-3 text-base">
                The route you requested does not match a skill, topic, or source
                page.
              </p>
              <div class="mt-5">
                <a
                  href="/skills"
                  class="text-parchment-700 hover:text-parchment-900 text-sm font-medium underline underline-offset-4"
                >
                  Browse all skills
                </a>
              </div>
            </div>
          ) : null
        }
      </div>
    </div>
  </div>
</Layout>
