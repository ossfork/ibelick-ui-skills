          </div>
          <p class="text-parchment-600 max-w-lg text-lg leading-snug">
            UI Skills is a collection of design-engineering skills to help
            humans and agents create better interfaces.
          </p>
        </div>

        <div class="bg-parchment-200/40 rounded-[12px] p-4 sm:p-5">
          <h2 class="text-parchment-900 text-base font-medium text-balance">
            Agent, start here.
          </h2>
          <p
            class="text-parchment-600 mt-3 max-w-2xl text-base leading-snug text-pretty"
          >
            You are working on a UI task. Before reading or changing code, run:
          </p>
          <div class="mt-4 flex w-full">
            <CodeBlock
              className="w-full"
              mobileSurface
              wrapOnMobile
              lines={[
                [
                  {
                    text: "npx",
                    className: "text-[#953800]",
                  },
                  {
                    text: " ui-skills start",
                    className: "text-[#0550ae]",
                  },
                ],
                [
                  {
                    text: "npx",
                    className: "text-[#953800]",
                  },
                  {
                    text: " ui-skills categories",
                    className: "text-[#0550ae]",
                  },
                ],
                [
                  {
                    text: "npx",
                    className: "text-[#953800]",
                  },
                  {
                    text: " ui-skills list --category",
                    className: "text-[#0550ae]",
                  },
                  {
                    text: " <category>",
                    className: "text-parchment-400",
                  },
                ],
                [
                  {
                    text: "npx",
                    className: "text-[#953800]",
                  },
                  {
                    text: " ui-skills get",
                    className: "text-[#0550ae]",
                  },
                  {
                    text: " <skill>",
                    className: "text-parchment-400",
                  },
                ],
              ]}
              copyContent={`npx ui-skills start
npx ui-skills categories
npx ui-skills list --category <category>
npx ui-skills get <skill>`}
            />
          </div>

          <p
            class="text-parchment-600 mt-4 max-w-2xl text-base leading-snug text-pretty"
          >
            Start with <code class="text-[0.875em]">npx ui-skills start</code>.
            Load the smallest relevant skill, then implement. Do not choose
            manually from the collection below.
          </p>
        </div>

        <div class="px-4 sm:px-0">
          <h2 class="text-parchment-900 text-base font-medium text-balance">
            Collection
          </h2>
          <div class="mt-3 grid gap-4 sm:grid-cols-2">
            {
              displayedSkills.map((skill) => (
                <SkillCard
                  href={`/skills/${skill.pathSlug}`}
                  slug={skill.slug}
                  description={skill.description}
                  ownerLabel={skill.ownerLabel}
                  avatarUrl={skill.avatarUrl}
                />
              ))
            }
          </div>
          <div class="mt-4 flex justify-center px-4 sm:px-0">
            <Button href="/skills"> See all skills </Button>
          </div>
        </div>
      </div>
    </div>
