---
type Props = {
  href: string;
  slug: string;
  description?: string;
  ownerLabel?: string;
  avatarUrl?: string;
};

const { href, slug, description, ownerLabel, avatarUrl } = Astro.props as Props;
---

<a
  href={href}
  class="hover:border-parchment-300 hover:bg-parchment-100 relative flex flex-col justify-between rounded-[12px] border border-neutral-200 bg-transparent px-6 py-4 transition-colors"
>
  <div class="flex flex-col gap-3">
    <div class="text-parchment-900 font-[450] tracking-tight">{slug}</div>
    {
      description ? (
        <div class="text-parchment-500 line-clamp-3 text-[14px] leading-snug">
          {description}
        </div>
      ) : null
    }
    {
      ownerLabel && avatarUrl ? (
        <div class="mt-1 flex items-center gap-2">
          <img
            src={avatarUrl}
            alt={`${ownerLabel} avatar`}
            width="20"
            height="20"
            loading="lazy"
            class="size-5 rounded-full border border-neutral-200"
          />
          <span class="text-parchment-500 text-[12px]">{ownerLabel}</span>
        </div>
      ) : null
    }
  </div>
</a>
